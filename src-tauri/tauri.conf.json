{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jirapp",
  "version": "0.2.0",
  "identifier": "com.kanfu.jirapp",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1430",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "jirapp — 設定",
        "width": 820,
        "height": 740,
        "minWidth": 480,
        "minHeight": 480,
        "resizable": true,
        "maximizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk5NkVEMTNERTJBMjY0OEMKUldTTVpLTGlQZEZ1bWZlbXd2Y0dNN0JLK2ZBODVVbzJWeU0vbmt6NE9QS1FPUGlvWlA4ai9DL1oK",
      "endpoints": [
        "https://github.com/comlinks/jirapp/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
